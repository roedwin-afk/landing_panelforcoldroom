---
import { Image } from "astro:assets";

import foodIndustry from "../assets/cold-room-panels-food-industry.png";
import pharmaceuticalIndustry from "../assets/cold-room-panels-pharmaceutical-industry.webp";
import logisticsDistribution from "../assets/cold-room-panels-logistics-distribution.jpg";
import agricultureIndustry from "../assets/cold-room-panels-agriculture-industry.jpg";

import { en } from '../i18n/en';
import { es } from '../i18n/es';

const locale = Astro.currentLocale ?? 'en';
const t = locale === 'es' ? es : en;


const applications = [
  {
    image: foodIndustry,
    title: t.applications.items.foodIndustry.title,
    text: t.applications.items.foodIndustry.text,
  },
  {
    image: pharmaceuticalIndustry,
    title: t.applications.items.pharmaceuticalIndustry.title,
    text: t.applications.items.pharmaceuticalIndustry.text,
  },
  {
    image: logisticsDistribution,
    title: t.applications.items.logisticsDistribution.title,
    text: t.applications.items.logisticsDistribution.text,
  },
  {
    image: agricultureIndustry,
    title: t.applications.items.agricultureIndustry.title,
    text: t.applications.items.agricultureIndustry.text,
  },
];
---

<section class="applications fade-in" id="applications">
  <div class="applications__container">
    <div class="applications__header">
      <h2 class="applications__title">{t.applications.title}</h2>

      <div class="applications__controls">
        <button
          class="applications__button applications__button--prev"
          type="button"
          aria-label="Previous application"
        >
          ‹
        </button>

        <button
          class="applications__button applications__button--next"
          type="button"
          aria-label="Next application"
        >
          ›
        </button>
      </div>
    </div>

    <div class="applications__slider">
      {
        applications.map((app, index) => (
          <article
            class={`applications__card ${index === 0 ? "is-active" : ""}`}
            data-index={index}
          >
            <div class="applications__image-wrap">
              <Image
                src={app.image}
                alt={`${app.title} cold room panels`}
                class="applications__img"
                width={420}
                height={280}
                format="webp"
                quality={80}
              />
            </div>

            <div class="applications__info">
              <h3 class="applications__name">{app.title}</h3>
              <p class="applications__text">{app.text}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="applications__dots" aria-label="Applications carousel navigation">
      {
        applications.map((_, index: number) => (
          <button
            class={`applications__dot ${index === 0 ? "is-active" : ""}`}
            type="button"
            aria-label={`Go to application ${index + 1}`}
            data-index={index}
          />
        ))
      }
    </div>
  </div>
</section>

<script src="../scripts/aplicaciones-carousel.ts"></script>

<style>
  .applications {
    padding: 5rem var(--container-padding);
    background-color: #f8f9fa;
    overflow: hidden;
  }

  .applications__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .applications__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .applications__title {
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
  }

  .applications__controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .applications__button {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(31, 58, 95, 0.15);
    border-radius: 999px;
    background: var(--color-white);
    color: var(--color-primary);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .applications__button:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .applications__slider {
    position: relative;
    height: 500px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }

  .applications__card {
    position: absolute;
    width: min(100%, 500px);
    background: var(--color-white);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
    transition:
      transform 0.7s ease,
      opacity 0.7s ease,
      filter 0.7s ease,
      box-shadow 0.7s ease;
    will-change: transform, opacity;
    opacity: 0;
    pointer-events: none;
  }

  .applications__card.is-active,
  .applications__card.is-left,
  .applications__card.is-right {
    opacity: 1;
    pointer-events: auto;
  }

  .applications__card.is-active {
    transform: translateX(0) scale(1);
    z-index: 3;
    filter: blur(0);
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
  }

  .applications__card.is-left {
    transform: translateX(-62%) scale(0.86);
    z-index: 2;
    opacity: 0.76;
    filter: grayscale(10%) brightness(0.92);
  }

  .applications__card.is-right {
    transform: translateX(62%) scale(0.86);
    z-index: 2;
    opacity: 0.76;
    filter: grayscale(10%) brightness(0.92);
  }

  .applications__card.is-hidden-left {
    transform: translateX(-135%) scale(0.68);
    z-index: 1;
    opacity: 0;
    filter: blur(2px);
  }

  .applications__card.is-hidden-right {
    transform: translateX(135%) scale(0.68);
    z-index: 1;
    opacity: 0;
    filter: blur(2px);
  }

  .applications__image-wrap {
    position: relative;
  }

  .applications__img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .applications__info {
    padding: 1.35rem;
    text-align: center;
  }

  .applications__name {
    color: var(--color-primary);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.65rem;
  }

  .applications__text {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .applications__dots {
    display: flex;
    justify-content: center;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .applications__dot {
    width: 10px;
    height: 10px;
    border: none;
    border-radius: 999px;
    background: rgba(31, 58, 95, 0.25);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .applications__dot.is-active {
    background: var(--color-accent);
    transform: scale(1.15);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 991px) {
    .applications__slider {
      height: 470px;
    }

    .applications__card {
      width: min(100%, 340px);
    }

    .applications__card.is-left {
      transform: translateX(-58%) scale(0.8);
    }

    .applications__card.is-right {
      transform: translateX(58%) scale(0.8);
    }
  }

  @media (max-width: 768px) {
    .applications {
      padding: 3rem var(--container-padding-mobile);
    }

    .applications__header {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }

    .applications__controls {
      align-self: flex-end;
    }

    .applications__slider {
      height: 430px;
    }

    .applications__card {
      width: min(100%, 300px);
    }

    .applications__card.is-left {
      transform: translateX(-32%) scale(0.72);
      opacity: 0.38;
    }

    .applications__card.is-right {
      transform: translateX(32%) scale(0.72);
      opacity: 0.38;
    }

    .applications__img {
      height: 200px;
    }

    .applications__text {
      font-size: 0.92rem;
    }
  }

  @media (max-width: 480px) {
    .applications__slider {
      height: 410px;
    }

    .applications__card {
      width: min(100%, 280px);
    }

    .applications__card.is-left {
      transform: translateX(-24%) scale(0.68);
      opacity: 0.25;
    }

    .applications__card.is-right {
      transform: translateX(24%) scale(0.68);
      opacity: 0.25;
    }
  }
</style>