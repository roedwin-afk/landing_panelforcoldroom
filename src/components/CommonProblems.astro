---
import { Thermometer, AlertTriangle, Wrench } from "@lucide/astro";
import { en } from '../i18n/en';
import { es } from '../i18n/es';

const locale = Astro.currentLocale ?? 'en';
const t = locale === 'es' ? es : en;

const icons = {
  temperature: Thermometer,
  compliance: AlertTriangle,
  installation: Wrench,
};

type IconName = "temperature" | "compliance" | "installation";
const problems = t.problems.items;
---

<section class="problems fade-in" id="problems">
  <div class="problems__container">
    <h2 class="problems__section-title">
      {t.problems.sectionTitle}
    </h2>

    <div class="problems__grid">
      {
        problems.map((p) => (
          <div class="problems__card">
            <span class="problems__icon">
              {(() => {
                const Icon = icons[p.icon];
                return Icon ? <Icon size={28} /> : null;
              })()}
            </span>

            <h3 class="problems__title">{p.title}</h3>
            <p class="problems__text">{p.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problems {
    padding: 5rem var(--container-padding);
    background-color: #f8f9fa;
  }

  .problems__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .problems__section-title {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .problems__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .problems__card {
    text-align: center;
    padding: 2rem 1rem;
    border-top: 3px solid var(--color-accent);
    background-color: var(--color-white);
  }

  .problems__card:hover .problems__icon svg {
    stroke: var(--color-accent);
  }

  .problems__icon {
    display: block;
    margin-bottom: 0.75rem;
  }

  .problems__icon svg {
    width: 28px;
    height: 28px;
    stroke: var(--color-primary);
  }

  .problems__title {
    color: var(--color-primary);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .problems__text {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .problems {
      padding: 3rem var(--container-padding-mobile);
    }

    .problems__text {
      font-size: 1rem;
    }

    .problems__card {
      padding: 1.5rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .problems__grid {
      grid-template-columns: 1fr;
    }
  }
</style>