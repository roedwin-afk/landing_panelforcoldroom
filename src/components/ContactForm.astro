---
import { Mail, Phone, MapPin } from "@lucide/astro";
---

<section class="contact fade-in" id="contact">
  <div class="contact__container">
    <div class="contact__info">
      <h2>Request Your Quote</h2>
      <p>
        Contact us for expert guidance in selecting the right cold room panels
        for your project. We will get back to you as soon as possible.
      </p>

      <div class="contact__data">
        <p>
          <Mail size={18} />
          <a href="mailto:info@panelforcoldroom.com">
            info@panelforcoldroom.com
          </a>
        </p>

        <p>
          <Phone size={18} />
          <a href="tel:+525599903546">+52 55 9990 3546</a>
        </p>

        <p>
          <MapPin size={18} />
          <a
          href="https://maps.google.com/?cid=15759084979067732314&g_mp=Cidnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLlNlYXJjaFRleHQ"
          aria-label="Google Maps"
          target="_blank"
        >
          Avenida Presidente Masaryk No. 61, Int. 901, Polanco V Sección,
          C.P. 11560, Miguel Hidalgo, Mexico City, Mexico
          </a>
        </p>
      </div>

      <div class="contact__social">
        <a href="#" target="_blank" aria-label="Facebook">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 12a10 10 0 1 0-11.5 9.9v-7H8v-3h2.5V9.5c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.5.7-1.5 1.5V12H17l-.4 3h-2.7v7A10 10 0 0 0 22 12z"></path>
          </svg>
        </a>

        <a href="#" target="_blank" aria-label="Instagram">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 2C4.8 2 3 3.8 3 6v12c0 2.2 1.8 4 4 4h10c2.2 0 4-1.8 4-4V6c0-2.2-1.8-4-4-4H7zm5 5a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm6.5-1.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"></path>
          </svg>
        </a>

        <a href="#" target="_blank" aria-label="LinkedIn">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.6v2.2h.05c.5-.9 1.7-2.2 3.5-2.2 3.75 0 4.45 2.47 4.45 5.68V24h-4v-7.5c0-1.8-.03-4.1-2.5-4.1-2.5 0-2.9 1.95-2.9 4v7.6h-4V8z"></path>
          </svg>
        </a>

        <a href="https://wa.me/525599903546" target="_blank" aria-label="WhatsApp">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 3.5A11.9 11.9 0 0 0 12 .5C5.7.5.6 5.6.6 12c0 2.1.5 4.1 1.6 5.9L.5 23.5l5.7-1.5c1.7.9 3.6 1.4 5.8 1.4 6.3 0 11.4-5.1 11.4-11.4 0-3-1.2-5.8-3.4-8zM12 21c-1.8 0-3.5-.5-5-1.3l-.4-.2-3.4.9.9-3.3-.3-.4A9.5 9.5 0 1 1 12 21zm5.2-7.1c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.4-2.3-1.4-.8-.7-1.4-1.6-1.6-1.9-.2-.3 0-.5.1-.7.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.2-.7-1.7-1-2.3-.2-.5-.5-.4-.7-.4h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.2 1.4 3.4c.2.2 2.4 3.7 5.8 5.2.8.3 1.5.5 2 .7.8.3 1.5.3 2.1.2.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.2-.3-.3-.6-.5z"></path>
          </svg>
        </a>
      </div>

      <div class="contact__map">
        <iframe
          src="https://maps.google.com/maps?q=Avenida%20Presidente%20Masaryk%20No.%2061%2C%20Int.%20901%2C%20Polanco%20V%20Secci%C3%B3n%2C%20C.P.%2011560%2C%20Miguel%20Hidalgo%2C%20Mexico%20City%2C%20Mexico&output=embed"
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <form
      class="contact__form"
      action="https://formspree.io/f/maqlkvyj"
      method="POST"
    >
      <input type="hidden" name="_next" value="/thank-you" />

      <div class="form__row">
        <div class="form__group">
          <label for="first-name">First Name</label>
          <input
            type="text"
            id="first-name"
            name="first_name"
            placeholder="First Name"
            required
          />
        </div>

        <div class="form__group">
          <label for="last-name">Last Name</label>
          <input
            type="text"
            id="last-name"
            name="last_name"
            placeholder="Last Name"
            required
          />
        </div>
      </div>

      <div class="form__group">
        <label for="email">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="your@email.com"
          required
        />
      </div>

      <div class="form__group">
        <label for="phone">Phone</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="+52 00 0000 0000"
        />
      </div>

      <div class="form__group">
        <label for="message">Project Details</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Tell us about your project..."
          required
        ></textarea>
      </div>

      <button type="submit">Send Request →</button>
    </form>
  </div>
</section>

<style>
  .contact {
    padding: 4rem 2rem;
  }

  .contact__container {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }

  .contact__info h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .contact__info p {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .contact__data p {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .contact__data a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .contact__data a:hover {
    text-decoration: underline;
  }

  .contact__data svg {
    color: var(--color-primary);
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .contact__social {
    display: flex;
    gap: 1rem;
    margin: 1rem 0;
  }

  .contact__social a svg {
    color: var(--color-primary);
  }

  .contact__social a:hover svg {
    color: var(--color-accent);
  }

  .contact__map iframe {
    width: 100%;
    height: 220px;
    border: none;
    border-radius: 8px;
    margin-top: 1rem;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form__group label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .contact__form input,
  .contact__form textarea {
    padding: 0.9rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    transition: border 0.2s, box-shadow 0.2s;
  }

  .contact__form input:focus,
  .contact__form textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.2);
  }

  .contact__form button {
    background-color: var(--color-accent);
    color: white;
    padding: 1rem;
    border: none;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    border-radius: 4px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .contact__form button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .contact {
      padding: 3rem 1.5rem;
    }

    .contact__container {
      grid-template-columns: 1fr;
    }

    .contact__info h2 {
      font-size: 1.5rem;
    }

    .form__row {
      grid-template-columns: 1fr;
    }
  }
</style>