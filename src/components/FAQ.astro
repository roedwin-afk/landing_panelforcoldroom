---
import { en } from '../i18n/en';
import { es } from '../i18n/es';

const locale = Astro.currentLocale ?? 'en';
const t = locale === 'es' ? es : en;

const faqs = t.faqs.items;
---

<section class="faq-section fade-in">
    <div class="faq-section__container">
        <h2 class="faq-section__title">{t.faqs.title}</h2>

        <div class="faq-section__list">
            {
                faqs.map((faq, i) => (
                    <div class="faq-section__item">
                        <button class="faq-section__question" data-index={i}>
                            <span>{faq.question}</span>
                            <span class="faq-section__icon">+</span>
                        </button>

                        <div class="faq-section__answer">
                            <p>{faq.answer}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .faq-section {
        padding: 5rem var(--container-padding);
        background-color: #f8f9fb;
    }

    .faq-section__container {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-section__title {
        text-align: center;
        font-size: 1.75rem;
        color: var(--color-primary);
        margin-bottom: 2rem;
    }

    .faq-section__item {
        border-bottom: 1px solid #ddd;
    }

    .faq-section__question {
        width: 100%;
        background: none;
        border: none;
        padding: 1.2rem 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        text-align: left;
    }

    .faq-section__icon {
        font-size: 1.5rem;
        color: var(--color-accent);
        transition: transform 0.3s ease;
    }

    .faq-section__answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
    }

    .faq-section__answer p {
        padding-bottom: 1rem;
        color: #555;
        line-height: 1.6;
    }

    .faq-section__item.active .faq-section__answer {
        max-height: 200px;
    }

    .faq-section__item.active .faq-section__icon {
        transform: rotate(45deg);
    }

    @media (max-width: 768px) {
        .faq-section {
            padding: 3rem var(--container-padding-mobile);
        }
    }
</style>

<script>
    const items = document.querySelectorAll(".faq-section__item");

    items.forEach((item) => {
        const button = item.querySelector(".faq-section__question");

        if (!button) return;

        button.addEventListener("click", () => {
            const isActive = item.classList.contains("active");

            items.forEach((i) => i.classList.remove("active"));

            if (!isActive) {
                item.classList.add("active");
            }
        });
    });
</script>