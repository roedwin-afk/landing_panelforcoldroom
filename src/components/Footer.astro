---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import { en } from '../i18n/en';
import { es } from '../i18n/es';
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? 'en';
const t = locale === 'es' ? es : en;
const currentPath = Astro.url.pathname.replace(/^\/(en|es)/, '') || '/';
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__brand">
      
      <div class="lang-switcher">
        
          <a href={getRelativeLocaleUrl("en", currentPath)}
          class={`lang-btn ${locale === "en" ? "active" : ""}`}>EN</a>
        <div class="lang-divider"></div>
        
          <a href={getRelativeLocaleUrl("es", currentPath)}
          class={`lang-btn ${locale === "es" ? "active" : ""}`}>ES</a>
      </div>
      <div class="footer__top">
        <Image
          src={logo}
          alt="Panel for Cold Room Logo"
          class="footer__logo-img"
          width={200}
          height={50}
          loading="eager"
        />

      </div>


      <p class="footer__desc">
        {t.footer.description}
      </p>
    </div>

    <div class="footer__links">
      <h4>{t.footer.footer_links.navigation}</h4>
      <a href={getRelativeLocaleUrl(locale, "/") + "solution"}>{t.footer.footer_links.solution}</a>
      <a href={getRelativeLocaleUrl(locale, "/") + "blog/"}>{t.footer.footer_links.blog}</a>
      <a href={getRelativeLocaleUrl(locale, "/") + "contact/"}>{t.footer.footer_links.contact}</a>
    </div>

    <div class="footer__contact">
      <h4>{t.footer.footer_links.contact}</h4>

      <p>
        <a href="mailto:info@panelforcoldroom.com">
          info@panelforcoldroom.com
        </a>
      </p>

      <p>
        <a href="tel:+525599903546">+52 55 9990 3546</a>
      </p>

      <p>
        
          <a href="https://maps.google.com/?cid=15759084979067732314&g_mp=Cidnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLlNlYXJjaFRleHQ"
          aria-label="Google Maps"
          target="_blank"
        >
          Masaryk 61, Int. 901, Polanco V, 11560, CDMX
        </a>
      </p>

      <div class="footer__social">
        <a href="#" target="_blank" aria-label="Facebook">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 12a10 10 0 1 0-11.5 9.9v-7H8v-3h2.5V9.5c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.5.7-1.5 1.5V12H17l-.4 3h-2.7v7A10 10 0 0 0 22 12z"></path>
          </svg>
        </a>

        <a href="#" target="_blank" aria-label="Instagram">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 2C4.8 2 3 3.8 3 6v12c0 2.2 1.8 4 4 4h10c2.2 0 4-1.8 4-4V6c0-2.2-1.8-4-4-4H7zm5 5a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm6.5-1.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"></path>
          </svg>
        </a>

        <a href="#" target="_blank" aria-label="LinkedIn">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.6v2.2h.05c.5-.9 1.7-2.2 3.5-2.2 3.75 0 4.45 2.47 4.45 5.68V24h-4v-7.5c0-1.8-.03-4.1-2.5-4.1-2.5 0-2.9 1.95-2.9 4v7.6h-4V8z"></path>
          </svg>
        </a>

        <a href="https://wa.me/525599903546" target="_blank" aria-label="WhatsApp">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 3.5A11.9 11.9 0 0 0 12 .5C5.7.5.6 5.6.6 12c0 2.1.5 4.1 1.6 5.9L.5 23.5l5.7-1.5c1.7.9 3.6 1.4 5.8 1.4 6.3 0 11.4-5.1 11.4-11.4 0-3-1.2-5.8-3.4-8zM12 21c-1.8 0-3.5-.5-5-1.3l-.4-.2-3.4.9.9-3.3-.3-.4A9.5 9.5 0 1 1 12 21zm5.2-7.1c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.1-.2.2-.3.2-.6.1-.3-.2-1.2-.4-2.3-1.4-.8-.7-1.4-1.6-1.6-1.9-.2-.3 0-.5.1-.7.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.6 0-.2-.7-1.7-1-2.3-.2-.5-.5-.4-.7-.4h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1.1-1.1 2.7s1.2 3.2 1.4 3.4c.2.2 2.4 3.7 5.8 5.2.8.3 1.5.5 2 .7.8.3 1.5.3 2.1.2.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.2-.3-.3-.6-.5z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="footer__copy">
    <p>© <span id="year"></span> Panel for Cold Room</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #0f2337;
    color: rgba(255, 255, 255, 0.75);
    padding: 4rem 2rem 2rem;
  }

  .footer__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .footer__logo-img {
    height: 5rem;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .footer__desc {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer__links h4,
  .footer__contact h4 {
    color: var(--color-white);
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .footer__contact a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
  }

  .footer__contact a:hover {
    color: var(--color-accent);
  }

  .footer__links a {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__contact p {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .footer__copy {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    font-size: 0.85rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .footer__social a {
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .footer__social a:hover {
    color: var(--color-accent);
  }

  .lang-switcher {
    display: flex;
    flex-direction: row;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    overflow: hidden;
    width: max-content
  }

  .lang-btn {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.5px;
    text-decoration: none;
    display: inline-block;
  }

  .lang-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .lang-btn.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }

  .lang-divider {
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 768px) {
    .footer__container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__top {
      flex-direction: row;
      align-items: center;
    }
  }
</style>

<script>
  const el = document.getElementById("year");
  if (el) el.textContent = String(new Date().getFullYear());
</script>