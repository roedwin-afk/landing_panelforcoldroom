---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import Menu from "./Menu.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
const locale = Astro.currentLocale ?? "en";

const currentPath = Astro.url.pathname.replace(/^\/(en|es)/, '') || '/';
---

<header class="header">
  <div class="header__container">
    <div class="header__logo">
      <a href={getRelativeLocaleUrl(locale, "/")}>
        <Image
          src={logo}
          alt="Panel for Cold Room Logo"
          class="header__logo-img"
          width={200}
          height={50}
          loading="eager"
        />
      </a>
    </div>

    <nav class="header__nav">
      <Menu />
      <div class="lang-switcher">
        <a
          href={getRelativeLocaleUrl("en", currentPath)}
          class:list={["lang-btn", { active: locale === "en" }]}>EN</a
        >
        <div class="lang-divider"></div>
        <a
          href={getRelativeLocaleUrl("es", currentPath)}
          class:list={["lang-btn", { active: locale === "es" }]}>ES</a
        >
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-primary);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
  }

  .header__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header__nav {
    display: flex;
    gap: 2rem;
  }

  .header__logo {
    /* Quitamos el width fijo de 600px para que no empuje otros elementos */
    height: 3.5rem;
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    height: 5rem;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .header__logo a {
    display: inline-block;
    cursor: pointer;
  }

  .lang-switcher {
    display: flex;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    overflow: hidden;
  }

  .lang-btn {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.5px;
    text-decoration: none; /* agregado */
    display: inline-block; /* agregado */
  }

  .lang-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .lang-btn.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }

  .lang-divider {
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 768px) {
    .header__container {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem 0;
    }

    .header__nav {
      gap: 1.25rem;
    }
  }
</style>
