---
import { Image } from "astro:assets";
import logo from "../assets/panel-for-cold-room-logo.png";
---

<header class="header">
  <div class="header__container">
    <div class="header__logo">
      <a href="/">
        <Image
          src={logo}
          alt="Panel for Cold Room Logo"
          class="header__logo-img"
          width={200}
          height={50}
          loading="eager"
        />
      </a>
    </div>

    <nav class="header__nav">
      <a href="#solution">Solutions</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-primary);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
  }

  .header__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header__nav {
    display: flex;
    gap: 2rem;
  }

  .header__nav a {
    color: var(--color-white);
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .header__nav a:hover {
    color: var(--color-accent);
  }

  .header__logo a {
    display: inline-block;
    cursor: pointer;
  }
  @media (max-width: 768px) {
  .header__container {
    flex-direction: column;
    gap: 1rem;
    padding: 1rem 0;
  }

  .header__nav {
    gap: 1.25rem;
  }

  .header__nav a {
    font-size: 0.85rem;
  }
}
</style>