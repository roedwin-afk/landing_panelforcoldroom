---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import Menu from "./Menu.astro";
---

<header class="header">
  <div class="header__container">
    <div class="header__logo">
      <a href="/">
        <Image
          src={logo}
          alt="Panel for Cold Room Logo"
          class="header__logo-img"
          width={200}
          height={50}
          loading="eager"
        />
      </a>
    </div>

    <nav class="header__nav">
      <Menu />
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-primary);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
  }

  .header__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header__nav {
    display: flex;
    gap: 2rem;
  }

  .header__logo {
    /* Quitamos el width fijo de 600px para que no empuje otros elementos */
    height: 3.5rem;
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    /* Forzamos a que el logo crezca ignorando el espacio en blanco interno */
    height: 50px;
    width: 3rem;
    /* Un pequeño truco de escala si sigue viéndose pequeño */
    transform: scale(5.5);
    transform-origin: center;
  }

  .header__logo a {
    display: inline-block;
    cursor: pointer;
  }
  @media (max-width: 768px) {
    .header__container {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem 0;
    }

    .header__nav {
      gap: 1.25rem;
    }
  }
</style>
