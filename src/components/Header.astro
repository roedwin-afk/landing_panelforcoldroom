---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import Menu from "./Menu.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
const locale = Astro.currentLocale ?? "en";
const currentPath = Astro.url.pathname.replace(/^\/(en|es)/, '') || '/';
---

<header class="header">
  <div class="header__container">
    <div class="header__logo">
      <a href={getRelativeLocaleUrl(locale, "/")}>
        <Image
          src={logo}
          alt="Panel for Cold Room Logo"
          class="header__logo-img"
          width={200}
          height={50}
          loading="eager"
        />
      </a>
    </div>

    <button class="header__toggle" id="menu-toggle">☰</button>

    <nav class="header__nav" id="menu">
      <Menu />
      <div class="lang-switcher">
        
          <a href={getRelativeLocaleUrl("en", currentPath)}
          class={`lang-btn ${locale === "en" ? "active" : ""}`}>EN</a>
        <div class="lang-divider"></div>
        
          <a href={getRelativeLocaleUrl("es", currentPath)}
          class={`lang-btn ${locale === "es" ? "active" : ""}`}>ES</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-primary);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
  }

  .header__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header__logo {
    height: 3.5rem;
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    height: 5rem;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .header__logo a {
    display: inline-block;
    cursor: pointer;
  }

  .header__toggle {
    display: none;
    font-size: 1.8rem;
    background: none;
    border: none;
    color: white;
    cursor: pointer;
  }

  .lang-switcher {
    display: flex;
    flex-direction: row;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    overflow: hidden;
  }

  .lang-btn {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.5px;
    text-decoration: none;
    display: inline-block;
  }

  .lang-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .lang-btn.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }

  .lang-divider {
    width: 1px;
    height: 16px;
    background: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 768px) {
    .header__container {
      position: relative;
    }

    .header__logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .header__toggle {
      display: block;
      margin-left: auto;
    }

    .header__nav {
      position: absolute;
      top: 100%;
      left: -2rem;
      width: calc(100% + 4rem);
      background-color: var(--color-primary);
      flex-direction: column;
      align-items: flex-end;
      gap: 1rem;
      padding: 1rem 2rem;
      box-sizing: border-box;
      display: none;
    }

    .header__nav.active {
      display: flex;
    }

    .lang-switcher {
      flex-direction: row;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("menu");

    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        menu.classList.toggle("active");
      });
      menu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menu.classList.remove("active");
        });
      });
    }
  });
</script>