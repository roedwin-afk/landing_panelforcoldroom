---
import polyurethanePanels from "../assets/polyurethane-cold-room-panels-el-salvador.webp";
---

<section class="hero fade-in">
  <div class="hero__bg"></div>

  <div class="hero__content">
    <div class="hero__card">
      <h1 class="hero__title">
        Cold Room Panels for Industrial Refrigeration
      </h1>

      <p class="hero__description">
        High-performance polyurethane panels for cold rooms, food processing, and
        temperature-controlled facilities. Designed for thermal efficiency,
        durability, and demanding industrial environments.
      </p>

      <a href="/contact" class="hero__btn">
        Request a Quote →
      </a>

      <p class="hero__trust">
        Trusted for industrial cold storage projects
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-image: url("/src/assets/polyurethane-cold-room-panels-el-salvador.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: rgba(10, 20, 40, 0.42);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    width: 100%;
    text-align: center;
  }

  .hero__card {
    background: rgba(18, 44, 68, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    padding: 3rem 3.5rem;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .hero__title {
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  .hero__description {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero__btn {
    display: inline-block;
    background-color: var(--color-accent);
    color: #ffffff;
    padding: 1rem 2.5rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .hero__btn:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .hero__trust {
    margin-top: 1.2rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.92rem;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
      padding: 2rem 1.2rem;
      background-position: 25% center;
    }

    .hero__card {
      padding: 2rem 1.5rem;
    }

    .hero__title {
      font-size: 1.9rem;
    }

    .hero__description {
      font-size: 1rem;
    }

    .hero__trust {
      font-size: 0.88rem;
    }
  }
</style>