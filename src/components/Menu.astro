---
import { en } from '../i18n/en';
import { es } from '../i18n/es';
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? 'en';
const t = locale === 'es' ? es : en;
---

<a href={getRelativeLocaleUrl(locale, "/solution/") }>
  {t.menu.solution}
</a>
<a href={getRelativeLocaleUrl(locale, "/blog/")}>{t.menu.blog}</a>
<a href={getRelativeLocaleUrl(locale, "/contact/")}>{t.menu.contact}</a>

<style>
  a {
    color: var(--color-white);
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {

    a {
      font-size: 0.85rem;
    }
  }

</style>