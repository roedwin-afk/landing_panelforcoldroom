---
import { Image } from "astro:assets";
import polyurethanePanels from "../assets/polyurethane-insulated-panels.webp";
import { en } from "../i18n/en";
import { es } from "../i18n/es";
import { getRelativeLocaleUrl } from "astro:i18n";

const locale = Astro.currentLocale ?? "en";
const t = locale === "es" ? es : en;
---

<section class="solution fade-in" id="solution">
  <div class="solution__container">
    <div class="solution__image">
      <Image
        src={polyurethanePanels}
        alt="Polyurethane insulated panel for cold room"
        width={600}
        height={400}
        format="webp"
        quality={80}
      />
    </div>

    <div class="solution__content">
      <h2 class="solution__title">
        {t.solution.title}
      </h2>

      <p class="solution__text">
        {t.solution.text}
      </p>

      <ul class="solution__list">
        {
          t.solution.features.map((feature) => (
            <li class="solution__item">
              <span class="solution__check">✓</span>
              {feature}
            </li>
          ))
        }
      </ul>
      <a
        href={getRelativeLocaleUrl(locale, "/solution/")}
        class="solution__button"
      >
        {locale === "es" ? "Ver solución completa" : "Learn more"}
      </a>
    </div>
  </div>
</section>

<style>
  .solution {
    padding: 5rem var(--container-padding);
    background-color: var(--color-white);
  }

  .solution__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .solution__image img {
    border-radius: 8px;
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  .solution__title {
    color: var(--color-primary);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1.25rem;
  }

  .solution__text {
    color: #555;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .solution__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .solution__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .solution__check {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .solution__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    padding: 0.9rem 1.4rem;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: 0.25s ease;
  }

  .solution__button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  @media (max-width: 768px) {
    .solution {
      padding: 3rem var(--container-padding-mobile);
    }

    .solution__container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
