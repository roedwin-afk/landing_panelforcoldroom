---
import { Image } from "astro:assets";
import polyurethanePanels from "../assets/polyurethane-insulated-panels.webp";
import { getRelativeLocaleUrl } from "astro:i18n";
import { en } from "../i18n/en";
import { es } from "../i18n/es";

import {
  Snowflake,
  Thermometer,
  Beef,
  Milk,
  Package,
  ChefHat,
  Pill,
} from "@lucide/astro";

const iconos = {
  cold: Snowflake,
  temp: Thermometer,
  freeze: Snowflake,
  meat: Beef,
  dairy: Milk,
  distribution: Package,
  kitchen: ChefHat,
  pharma: Pill,
} as const;

type IconoAplicacion = keyof typeof iconos;
type AplicacionItem = {
  icon: IconoAplicacion;
  text: string;
};

const locale = Astro.currentLocale ?? "en";
const t = locale === "es" ? es : en;

const data = t.solutionPage;
const aplicaciones = data.applications.items as AplicacionItem[];
---

<main class="solution-page">
  <section class="solution-hero">
    <div class="solution-hero__container">
      <div class="solution-hero__content">
        <span class="solution-hero__eyebrow">{data.hero.eyebrow}</span>

        <h1 class="solution-hero__title">{data.hero.title}</h1>
        <p class="solution-hero__text">{data.hero.text}</p>

        <div class="solution-hero__actions">
          <a
            href={getRelativeLocaleUrl(locale, "/contact/")}
            class="btn btn--primary"
          >
            {data.hero.primaryCta}
          </a>

          <a href="#applications" class="btn btn--secondary">
            {data.hero.secondaryCta}
          </a>
        </div>
      </div>

      <div class="solution-hero__media">
        <div class="solution-hero__image-wrap">
          <Image
            src={polyurethanePanels}
            alt={data.hero.imageAlt}
            width={700}
            height={560}
            format="webp"
            quality={85}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="problems">
    <div class="section-head">
      <span class="section-head__kicker">{data.problems.kicker}</span>
      <h2>{data.problems.title}</h2>
    </div>

    <div class="problems__grid">
      {
        data.problems.items.map((item) => (
          <article class="problem-card">
            <span class="problem-card__icon">•</span>
            <p>{item}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="overview">
    <div class="overview__container">
      <div class="overview__content">
        <span class="section-label">{data.overview.kicker}</span>
        <h2>{data.overview.title}</h2>
        <p>{data.overview.text1}</p>
        <p>{data.overview.text2}</p>
      </div>

      <div class="overview__stats">
        {
          data.overview.stats.map((item) => (
            <div class="stat-card">
              <strong>{item.label}</strong>
              <span>{item.value}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="benefits">
    <div class="section-head">
      <span class="section-head__kicker">{data.benefits.kicker}</span>
      <h2>{data.benefits.title}</h2>
    </div>

    <div class="benefits__grid">
      {
        data.benefits.items.map((item) => (
          <article class="benefit-card">
            <div class="benefit-card__top">
              <span class="benefit-card__check">✓</span>
              <h3>{item.title}</h3>
            </div>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="applications" id="applications">
    <div class="section-head">
      <span class="section-head__kicker">{data.applications.kicker}</span>
      <h2>{data.applications.title}</h2>
    </div>

    <div class="applications__grid">
      {
        aplicaciones.map((item) => {
          const Icono = iconos[item.icon];

          return (
            <article class="application-card">
              <span class="application-card__icon">
                <Icono size={22} stroke-width={2} />
              </span>
              <p>{item.text}</p>
            </article>
          );
        })
      }
    </div>
  </section>

  <section class="process">
    <div class="section-head">
      <span class="section-head__kicker">{data.process.kicker}</span>
      <h2>{data.process.title}</h2>
    </div>

    <div class="process__grid">
      {
        data.process.items.map((item) => (
          <article class="process-card">
            <span class="process-card__step">{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="comparison">
    <div class="section-head">
      <span class="section-head__kicker">{data.comparison.kicker}</span>
      <h2>{data.comparison.title}</h2>
    </div>

    <div class="comparison__list">
      {
        data.comparison.rows.map((row) => (
          <article class="comparison-card">
            <div class="comparison-card__aspect">
              <span class="comparison-card__label">
                {data.comparison.headers.aspect}
              </span>
              <h3>{row.aspect}</h3>
            </div>

            <div class="comparison-card__columns">
              <div class="comparison-card__col comparison-card__col--solution">
                <span class="comparison-card__col-title">
                  {data.comparison.headers.solution}
                </span>
                <p>
                  <span class="comparison-card__icon comparison-card__icon--ok">
                    ✓
                  </span>
                  {row.solution}
                </p>
              </div>

              <div class="comparison-card__col comparison-card__col--other">
                <span class="comparison-card__col-title">
                  {data.comparison.headers.other}
                </span>
                <p>
                  <span class="comparison-card__icon comparison-card__icon--other">
                    —
                  </span>
                  {row.other}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="faq">
    <div class="section-head">
      <span class="section-head__kicker">{data.faq.kicker}</span>
      <h2>{data.faq.title}</h2>
    </div>

    <div class="faq__list">
      {
        data.faq.items.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="solution-cta">
    <div class="solution-cta__box">
      <div class="solution-cta__content">
        <span class="solution-cta__kicker">{data.cta.kicker}</span>
        <h2>{data.cta.title}</h2>
        <p>{data.cta.text}</p>
      </div>

      <a
        href={getRelativeLocaleUrl(locale, "/contact/")}
        class="btn btn--light"
      >
        {data.cta.button}
      </a>
    </div>
  </section>
</main>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .solution-page {
    background:
      radial-gradient(
        circle at top left,
        rgba(20, 91, 154, 0.08),
        transparent 28%
      ),
      linear-gradient(180deg, #ffffff 0%, #f7f9fc 100%);
  }

  .solution-hero,
  .problems,
  .overview,
  .benefits,
  .applications,
  .process,
  /* .comparison, */
  .faq,
  .solution-cta {
    padding: 5rem var(--container-padding);
  }

  .solution-hero {
    padding-top: 7rem;
  }

  .solution-hero__container,
  .overview__container,
  .section-head,
  .comparison__table-wrap,
  .faq__list,
  .solution-cta__box,
  .problems__grid,
  .benefits__grid,
  .applications__grid,
  .process__grid {
    max-width: 1200px;
    margin: 0 auto;
  }

  .solution-hero__container {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 3rem;
  }

  .solution-hero__eyebrow,
  .section-head__kicker,
  .section-label,
  .solution-cta__kicker {
    display: inline-block;
    margin-bottom: 0.9rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .solution-hero__title {
    font-size: clamp(2.2rem, 4vw, 4rem);
    line-height: 1.08;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    max-width: 12ch;
  }

  .solution-hero__text {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #55606f;
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  .solution-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0.95rem 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn--primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 12px 30px rgba(20, 91, 154, 0.18);
  }

  .btn--secondary {
    background: rgba(20, 91, 154, 0.08);
    color: var(--color-primary);
    border: 1px solid rgba(20, 91, 154, 0.12);
  }

  .btn--light {
    background: white;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .solution-hero__image-wrap {
    position: relative;
    background: linear-gradient(180deg, #ffffff 0%, #edf3f9 100%);
    border: 1px solid rgba(20, 91, 154, 0.08);
    border-radius: 24px;
    padding: 1rem;
    box-shadow: 0 24px 60px rgba(10, 32, 58, 0.08);
  }

  .solution-hero__image-wrap img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    border-radius: 18px;
    display: block;
  }

  .section-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-head h2,
  .overview__content h2,
  .solution-cta__content h2 {
    font-size: clamp(1.75rem, 3vw, 2.6rem);
    line-height: 1.2;
    color: var(--color-primary);
    margin: 0;
  }

  .problems__grid,
  .benefits__grid,
  .applications__grid,
  .process__grid {
    display: grid;
    gap: 1.3rem;
  }

  .problems__grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .benefits__grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .applications__grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .process__grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .problem-card,
  .benefit-card,
  .application-card,
  .process-card,
  .stat-card {
    background: white;
    border: 1px solid rgba(20, 91, 154, 0.08);
    border-radius: 18px;
    box-shadow: 0 12px 30px rgba(10, 32, 58, 0.04);
  }

  .problem-card {
    padding: 1.4rem;
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .problem-card__icon {
    color: var(--color-accent);
    font-size: 1.4rem;
    line-height: 1;
    margin-top: -0.05rem;
    flex-shrink: 0;
  }

  .problem-card p,
  .benefit-card p,
  .application-card p,
  .process-card p,
  .overview__content p,
  .faq-item p,
  .solution-cta__content p {
    color: #596474;
    line-height: 1.75;
    margin: 0;
  }

  .overview__container {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 2rem;
    align-items: center;
  }

  .overview__content {
    max-width: 62ch;
  }

  .overview__content p {
    margin-top: 1.1rem;
  }

  .overview__stats {
    display: grid;
    gap: 1rem;
  }

  .stat-card {
    padding: 1.4rem 1.5rem;
  }

  .stat-card strong {
    display: block;
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: 0.35rem;
  }

  .stat-card span {
    color: #627081;
  }

  .benefit-card {
    padding: 1.5rem;
  }

  .benefit-card__top {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    margin-bottom: 0.85rem;
  }

  .benefit-card__check {
    display: inline-flex;
    width: 30px;
    height: 30px;
    align-items: center;
    justify-content: center;
    background: rgba(0, 168, 107, 0.1);
    color: var(--color-accent);
    border-radius: 999px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .benefit-card h3,
  .process-card h3 {
    margin: 0;
    color: var(--color-primary);
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .application-card {
    padding: 1.4rem 1.2rem;
    text-align: center;
    transition: all 0.25s ease;
  }

  .application-card:hover {
    transform: translateY(-4px);
  }

  .application-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    margin-bottom: 0.9rem;
    border-radius: 14px;
    background: rgba(20, 91, 154, 0.08);
    color: var(--color-primary);
  }

  .application-card__bullet {
    display: inline-block;
    width: 12px;
    height: 12px;
    margin-bottom: 0.9rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 8px rgba(0, 168, 107, 0.08);
  }

  .process-card {
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .process-card__step {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.9rem;
  }

  .comparison {
    position: relative;
  }

  .comparison__list {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    gap: 1rem;
  }

  .comparison-card {
    background: white;
    border: 1px solid rgba(20, 91, 154, 0.08);
    border-radius: 20px;
    padding: 1.4rem;
    box-shadow: 0 12px 30px rgba(10, 32, 58, 0.04);
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.25rem;
    align-items: stretch;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .comparison-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px rgba(10, 32, 58, 0.08);
  }

  .comparison-card__aspect {
    padding: 1rem;
    border-radius: 16px;
    background: linear-gradient(180deg, #f7fbff 0%, #eef5fb 100%);
    border: 1px solid rgba(20, 91, 154, 0.08);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .comparison-card__label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .comparison-card__aspect h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.4;
    color: var(--color-primary);
  }

  .comparison-card__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .comparison-card__col {
    border-radius: 16px;
    padding: 1rem 1.1rem;
    min-height: 100%;
  }

  .comparison-card__col--solution {
    background: rgba(0, 168, 107, 0.06);
    border: 1px solid rgba(0, 168, 107, 0.12);
  }

  .comparison-card__col--other {
    background: rgba(20, 91, 154, 0.04);
    border: 1px solid rgba(20, 91, 154, 0.08);
  }

  .comparison-card__col-title {
    display: inline-block;
    margin-bottom: 0.75rem;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
  }

  .comparison-card__col p {
    margin: 0;
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    color: #596474;
    line-height: 1.7;
  }

  .comparison-card__icon {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-weight: 800;
    font-size: 0.9rem;
    margin-top: 0.1rem;
  }

  .comparison-card__icon--ok {
    background: rgba(0, 168, 107, 0.14);
    color: var(--color-accent);
  }

  .comparison-card__icon--other {
    background: rgba(20, 91, 154, 0.08);
    color: var(--color-primary);
  }

  .faq__list {
    display: grid;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border: 1px solid rgba(20, 91, 154, 0.08);
    border-radius: 16px;
    padding: 1.2rem 1.3rem;
    box-shadow: 0 10px 25px rgba(10, 32, 58, 0.04);
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.5;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    margin-top: 0.9rem;
  }

  .solution-cta {
    padding-bottom: 6rem;
  }

  .solution-cta__box {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f4e83 100%);
    border-radius: 24px;
    padding: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    box-shadow: 0 20px 45px rgba(15, 78, 131, 0.22);
  }

  .solution-cta__content h2,
  .solution-cta__content p,
  .solution-cta__kicker {
    color: white;
  }

  .solution-cta__content p {
    max-width: 62ch;
    opacity: 0.92;
    margin-top: 0.8rem;
  }

  @media (max-width: 1024px) {
    .solution-hero__container,
    .overview__container {
      grid-template-columns: 1fr;
    }

    .problems__grid,
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .applications__grid,
    .process__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .solution-hero__title {
      max-width: 100%;
    }
  }
  @media (max-width: 900px) {
    .comparison-card {
      grid-template-columns: 1fr;
    }

    .comparison-card__columns {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .solution-hero,
    .problems,
    .overview,
    .benefits,
    .applications,
    .process,
    .comparison,
    .faq,
    .solution-cta {
      padding: 3.5rem var(--container-padding-mobile);
    }

    .solution-hero {
      padding-top: 5.5rem;
    }

    .problems__grid,
    .benefits__grid,
    .applications__grid,
    .process__grid {
      grid-template-columns: 1fr;
    }

    .solution-hero__image-wrap img {
      height: 340px;
    }

    .solution-cta__box {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.6rem;
    }

    .btn,
    .btn--light {
      width: 100%;
    }
  }
</style>
