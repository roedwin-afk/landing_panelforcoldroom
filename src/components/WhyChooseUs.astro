---
import { Clock3, Building2, MessageCircle, Award } from "@lucide/astro";

import { en } from '../i18n/en';
import { es } from '../i18n/es';

const locale = Astro.currentLocale ?? 'en';
const t = locale === 'es' ? es : en;

const icons = {
  clock: Clock3,
  building: Building2,
  message: MessageCircle,
  award: Award,
};

type IconName = "clock" | "building" | "message" | "award";

const stats = t.whyChooseUs.stats;
---

<section class="why-choose fade-in" id="why-choose">
  <div class="why-choose__container">
    <h2 class="why-choose__title">
      {t.whyChooseUs.title}
    </h2>

    <div class="why-choose__grid">
      {
        stats.map((s) => (
          <div class="why-choose__card">
            <span class="why-choose__icon">
              {(() => {
                const Icon = icons[s.icon];
                return Icon ? <Icon size={28} /> : null;
              })()}
            </span>

            <span class="why-choose__number">{s.number}</span>
            <p class="why-choose__text">{s.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why-choose {
    padding: 5rem var(--container-padding);
    background-color: var(--color-white);
  }

  .why-choose__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .why-choose__title {
    text-align: center;
    color: var(--color-primary);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
  }

  .why-choose__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .why-choose__card {
    text-align: center;
    padding: 2rem 1rem;
    border-top: 3px solid var(--color-accent);
  }

  .why-choose__card:hover .why-choose__icon svg {
    stroke: var(--color-accent);
  }

  .why-choose__icon {
    display: block;
    margin-bottom: 0.75rem;
  }

  .why-choose__icon svg {
    width: 28px;
    height: 28px;
    stroke: var(--color-primary);
  }

  .why-choose__number {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .why-choose__text {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .why-choose {
      padding: 3rem var(--container-padding-mobile);
    }

    .why-choose__text {
      font-size: 1rem;
    }

    .why-choose__card {
      padding: 1.5rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .why-choose__grid {
      grid-template-columns: 1fr;
    }
  }
</style>