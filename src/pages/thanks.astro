---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Thank You | Your Request Has Been Received"
  description="Thank you for contacting us. Our team will get back to you shortly with your cold room panel quote."
>
  <div class="thank-you">
    <h1>Thank You!</h1>

    <p>
      We have received your request. Our team will contact you shortly with more information.
    </p>

    <a href="/">← Back to Home</a>
  </div>
</Layout>

<style>
  .thank-you {
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1.5rem;
    padding: 4rem 2rem;
  }

  .thank-you h1 {
    font-size: 2.5rem;
    color: var(--color-primary);
  }

  .thank-you p {
    font-size: 1.1rem;
    color: #555;
  }

  .thank-you a {
    color: var(--color-accent);
    font-weight: 700;
  }
</style>